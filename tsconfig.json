{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESnext",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "dist",
    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true,
    "useUnknownInCatchVariables": false,
    "allowImportingTsExtensions": true,
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "exclude": ["node_modules"]
}
